# ============================================================================
# TEAMS MEETING SUMMARY - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
#
# This file contains all environment variables used by the application.
# Copy this file to .env and fill in the actual values for your environment.
# DO NOT commit .env to version control - it contains sensitive information.
#
# For detailed information about each variable, see ARCHITECTURE.md
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================

# Node.js environment (development, staging, production)
NODE_ENV=development

# Port for backend API server
PORT=3001

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend application URL (used for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Public API URL exposed to frontend (can be different from actual backend URL)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Application display name
NEXT_PUBLIC_APP_NAME=Teams Meeting Summary

# Application description
NEXT_PUBLIC_APP_DESCRIPTION=AI-powered Teams meeting transcript analysis and summary generation

# ============================================================================
# MONGODB DATABASE CONFIGURATION
# ============================================================================

# MongoDB root username
MONGO_ROOT_USER=admin

# MongoDB root password (use strong password in production)
MONGO_ROOT_PASSWORD=change_me_in_production

# MongoDB database name
MONGO_DATABASE=teams-meeting-summary

# Full MongoDB connection URI
# Format: mongodb://[username]:[password]@[host]:[port]/[database]?authSource=admin
# For local Docker: mongodb://admin:password@mongo:27017/teams-meeting-summary?authSource=admin
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb://admin:change_me_in_production@mongo:27017/teams-meeting-summary?authSource=admin

# ============================================================================
# JWT AUTHENTICATION CONFIGURATION
# ============================================================================

# Secret key for JWT signing (minimum 32 characters, use strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_in_production_min_32_characters_random_string

# JWT token expiration time in seconds (1 hour = 3600, 24 hours = 86400)
JWT_EXPIRATION=3600

# JWT refresh token expiration in seconds (30 days = 2592000)
JWT_REFRESH_EXPIRATION=2592000

# ============================================================================
# AZURE ACTIVE DIRECTORY (Azure AD) OAUTH CONFIGURATION
# ============================================================================

# Azure App Registration Application (Client) ID
# Get from: Azure Portal → Azure AD → App Registrations → Your App → Application ID
AZURE_CLIENT_ID=change_me_in_production

# Azure App Registration Client Secret value
# Get from: Azure Portal → Azure AD → App Registrations → Your App → Certificates & Secrets
AZURE_CLIENT_SECRET=change_me_in_production

# Azure AD Tenant ID (Directory ID)
# Get from: Azure Portal → Azure AD → App Registrations → Your App → Directory (tenant) ID
AZURE_TENANT_ID=change_me_in_production

# OAuth redirect URI (must match exactly in Azure portal)
# Format: https://[your-domain]/api/auth/callback
REDIRECT_URI=http://localhost:3001/api/auth/callback

# OAuth scopes requested from Microsoft Graph
# Default includes: User.Read, Calendars.Read, OnlineMeetings.Read, offline_access
AZURE_SCOPES=User.Read Calendars.Read OnlineMeetings.Read OnlineMeetingTranscript.Read.All offline_access

# ============================================================================
# OPENAI API CONFIGURATION
# ============================================================================

# OpenAI API key
# Get from: https://platform.openai.com/account/api-keys
# Format: sk-...
OPENAI_API_KEY=change_me_in_production

# OpenAI model for summarization
# Options: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo, etc.
OPENAI_MODEL=gpt-4

# OpenAI API base URL (use default unless using Azure OpenAI)
OPENAI_API_BASE=https://api.openai.com/v1

# Maximum tokens for OpenAI requests
OPENAI_MAX_TOKENS=2000

# Temperature for OpenAI responses (0-2, lower = more deterministic)
OPENAI_TEMPERATURE=0.7

# ============================================================================
# WHISPER TRANSCRIPTION CONFIGURATION
# ============================================================================

# OpenAI Whisper model for speech-to-text transcription
# Used as a fallback when Teams native transcripts are unavailable
OPENAI_WHISPER_MODEL=whisper-1

# Maximum recording file size in MB (recordings larger than this will be rejected)
MAX_RECORDING_SIZE_MB=500

# Whether to automatically use Whisper when no native transcript is available
# If false, users must manually trigger Whisper transcription
AUTO_WHISPER_FALLBACK=false

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Logging level (error, warn, info, debug, verbose)
LOG_LEVEL=info

# Enable request/response logging
LOG_REQUESTS=true

# Enable database query logging
LOG_QUERIES=false

# Logging format (simple, json, combined)
LOG_FORMAT=simple

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Session encryption key (use strong random string, minimum 32 characters)
ENCRYPTION_KEY=change_me_in_production_min_32_characters_random_string

# CORS allowed origins (comma-separated for multiple origins)
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Enable HTTPS/TLS only (set to true in production)
SECURE_ONLY=false

# HTTP Strict Transport Security max age (in seconds)
HSTS_MAX_AGE=31536000

# Content Security Policy enabled
CSP_ENABLED=true

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================

# Global rate limit (requests per minute)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# API-specific rate limits
RATE_LIMIT_AUTH=5
RATE_LIMIT_SEARCH=30
RATE_LIMIT_EXPORT=10

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Maximum file upload size (in bytes, 10MB default)
MAX_FILE_SIZE=10485760

# Allowed file types for uploads (comma-separated)
ALLOWED_FILE_TYPES=.pdf,.docx,.xlsx,.txt

# Upload directory
UPLOAD_DIR=./uploads

# ============================================================================
# PDF EXPORT CONFIGURATION
# ============================================================================

# PDF page size (letter, a4, legal)
PDF_PAGE_SIZE=letter

# PDF margins (in points)
PDF_MARGIN_TOP=36
PDF_MARGIN_RIGHT=36
PDF_MARGIN_BOTTOM=36
PDF_MARGIN_LEFT=36

# Include meeting recording URL in PDF
PDF_INCLUDE_RECORDING_URL=true

# Include participant list in PDF
PDF_INCLUDE_PARTICIPANTS=true

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================

# Email service provider (smtp, sendgrid, mailgun)
EMAIL_PROVIDER=smtp

# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=change_me_in_production
SMTP_PASSWORD=change_me_in_production
SMTP_FROM=noreply@example.com

# SendGrid API key (if using SendGrid)
SENDGRID_API_KEY=change_me_in_production

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================

# Cache provider (memory, redis, mongodb)
CACHE_PROVIDER=memory

# Redis configuration (if using Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache TTL (time to live) in seconds (1 hour = 3600)
CACHE_TTL=3600

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API version
API_VERSION=v1

# API prefix for routes
API_PREFIX=api

# Enable API documentation (Swagger/OpenAPI)
API_DOCS_ENABLED=true

# API documentation path
API_DOCS_PATH=api/docs

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Enable application performance monitoring
APM_ENABLED=false

# Application Insights instrumentation key (Azure)
APPINSIGHTS_INSTRUMENTATIONKEY=

# Sentry DSN (error tracking)
SENTRY_DSN=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable user registration
FEATURE_USER_REGISTRATION=true

# Enable PDF export
FEATURE_PDF_EXPORT=true

# Enable meeting search
FEATURE_MEETING_SEARCH=true

# Enable bulk operations
FEATURE_BULK_OPERATIONS=false

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Slack bot token (optional)
SLACK_BOT_TOKEN=

# Slack signing secret
SLACK_SIGNING_SECRET=

# ============================================================================
# DATABASE BACKUP CONFIGURATION
# ============================================================================

# Enable automatic backups
BACKUP_ENABLED=false

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup directory
BACKUP_DIR=./backups

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable hot reload in development
HOT_RELOAD=true

# Enable request debugging
DEBUG_REQUESTS=false

# Enable database seeding in development
SEED_DATABASE=false

# Enable mock API responses for testing
MOCK_API=false

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Replace all "change_me_in_production" values with actual values
# 2. Never commit the actual .env file to version control
# 3. Use strong, random values for secrets (minimum 32 characters)
# 4. For production, use environment-specific configuration management
# 5. Rotate secrets periodically
# 6. Use managed services for sensitive data (Azure Key Vault, AWS Secrets Manager)
#
# ============================================================================
